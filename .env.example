# Port the HTTP server listens on.
PORT=8080

# Shared bearer token. When set, every request to /convert/* must send
#   Authorization: Bearer <PDF_SERVICE_TOKEN>
# Leave unset ONLY for local development — the service refuses to start with
# auth disabled unless NODE_ENV=development.
PDF_SERVICE_TOKEN=

# Whether the headless renderer is allowed to fetch remote (http/https) resources
# such as <img src="https://..."> while rendering Markdown to PDF.
# Default false — the renderer only loads inline (data:) resources, which blocks
# SSRF / local-file exfiltration via crafted Markdown. Set to true only if you
# trust the Markdown source and need remote images.
PDF_ALLOW_REMOTE=false

# Max request body size accepted by the JSON / raw parsers.
MAX_BODY_SIZE=10mb

# Node environment. `development` relaxes the auth-required guard above.
NODE_ENV=development
